            box-shadow:0 2px 5px rgba(0,0,0,0.2); font-family:sans-serif; user-select:none;
        }
        #excel-toggle-btn:hover { background:#104e2b; }

        body.excel-mode {
            background:#fff !important;
            font-family:'DengXian','Calibri',sans-serif !important;
            font-size:11pt !important; color:#000 !important; margin:0 !important;
            padding-top:158px !important; padding-bottom:55px !important;
            overflow-x:hidden !important;
        }

        /* 隐藏 WAP 原生元素 */
        body.excel-mode .navbar,
        body.excel-mode #footer,
        body.excel-mode #gotofourmform,
        body.excel-mode ins.adsbygoogle
        { display:none !important; }

        /* 列表页隐藏顶部 <p>（面包屑+操作）；详情页单独处理 */
        body.excel-mode.forum-page #scroller > p
        { display:none !important; }

        /* 详情页：隐藏所有会产生空白的游离元素 */
        body.excel-mode.thread-page #scroller > span.paging,
        body.excel-mode.thread-page #scroller > br,
        body.excel-mode.thread-page #scroller > p:empty,
        body.excel-mode.thread-page #scroller > a[name],
        body.excel-mode.thread-page #scroller > b:not([class])
        { display:none !important; }

        /* 详情页：原始 <p> 中操作链接全部隐藏，只保留面包屑 */
        body.excel-mode.thread-page #scroller > p .op-links
        { display:none !important; }

        /* 面包屑导航条（详情页表格上方） */
        #tgfc-breadcrumb {
            padding:4px 8px 4px 8px;
            font-size:11pt;
            color:#333;
            border-bottom:1px solid #e1e1e1;
            background:#fff;
            line-height:22px;
        }
        #tgfc-breadcrumb a {
            color:#333 !important;
