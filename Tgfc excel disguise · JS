        .excel-ribbon { height:44px; background:#f3f2f1; display:flex; align-items:center; padding:0 10px; border-bottom:1px solid #d4d4d4; }
        .ribbon-divider { height:28px; width:1px; background:#ccc; margin:0 10px; }
        .font-settings select { height:20px; font-size:11px; border:1px solid #ccc; }
        .font-actions { margin-top:2px; font-size:12px; }
        .font-actions * { margin-right:5px; cursor:pointer; padding:0 2px; }
        .excel-formula-bar { display:flex; align-items:center; padding:3px 6px; background:white; border-bottom:1px solid #d4d4d4; }
