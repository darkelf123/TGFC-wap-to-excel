        body.excel-mode .td-meta {
            width:1px; white-space:nowrap; font-size:9pt; color:#888; text-align:right;
            vertical-align:top; padding:5px 8px !important;
            border-left:1px solid #ebebeb !important;
        }
        body.excel-mode .td-meta .post-time { display:block; color:#aaa; font-size:9pt; }
