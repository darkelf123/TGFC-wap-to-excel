        #formula-bar-content { flex:1; height:20px; line-height:20px; outline:none; font-family:'DengXian'; font-size:11pt; color:#333; overflow:hidden; white-space:nowrap; }
        #formula-bar-content a { color:#333; text-decoration:none; margin:0 2px; }
        #formula-bar-content a:hover { text-decoration:underline; color:#217346; }
        #formula-bar-content em { color:#999; font-style:normal; margin:0 2px; }
        .excel-col-headers { background:#f3f2f1; border-bottom:1px solid #d4d4d4; font-size:11px; color:#666; height:20px; line-height:20px; }
        /* 列表页：列头用 display:table 和内容完全一致，保证对齐 */
                /* 列表页列头已改为表格内第一行，flex列头隐藏 */
        body.excel-mode.forum-page .excel-col-headers { display:none !important; }
        /* 详情页：列头用 flex（保持原有行为）*/
        body.excel-mode.thread-page .excel-col-headers { display:flex; }
        body.excel-mode.thread-page .excel-col-headers > div { border-right:1px solid #d4d4d4; padding:0 4px; }
