        }

        /* ── 公共 Excel UI ── */
        #excel-fake-header { display:none; }
        body.excel-mode #excel-fake-header {
            display:block; position:fixed; top:0; left:0; width:100%;
            z-index:9999; background:#f3f2f1; border-bottom:1px solid #ccc; box-sizing:border-box;
        }
